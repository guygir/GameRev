# Browser (Vite inlines at build). Set the same in Vercel → Environment Variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server only (Vite dev + Vercel functions). Never VITE_ prefix.
SUPABASE_SERVICE_ROLE_KEY=
ADD_GAME_PASSWORD=

# Optional: IGDB external genre search on /addgame (Twitch developer app; server-side only).
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# Optional: Backloggd “Cloud AI” refinement (server-side only; no local GPU). Set one or both.
# OpenAI: pay-as-you-go — https://platform.openai.com/docs/pricing
OPENAI_API_KEY=
# Google Gemini: AI Studio keys get limited free quota (Flash / Flash-Lite; see rate limits).
# https://ai.google.dev/pricing — https://ai.google.dev/gemini-api/docs/rate-limits
GEMINI_API_KEY=
# Optional: try this model first (must match an ID in src/lib/geminiBackloggdModels.ts; then other Flash models).
# Wrong IDs return HTTP 404 (not “out of tokens”). Rate / quota limits are usually 429 — see Gemini rate limits.
# List names for your key: GET https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_KEY
GEMINI_MODEL=
# Add Game → Backloggd “Cloud AI” can also pick a whitelisted free-tier model in the UI (sent as geminiModel); that wins over GEMINI_MODEL for the first Gemini attempt.

# Optional: mirror reader comments to GitHub (one issue per game; PAT needs Issues read+write on the repo).
# The suggestion box reuses this same token/repo, creating standalone suggestion issues.
GITHUB_COMMENTS_TOKEN=
GITHUB_COMMENTS_REPO=owner/repo

# Optional: newsletter via Buttondown (no custom domain required; Buttondown handles opt-in/unsubscribe).
BUTTONDOWN_API_KEY=

# Optional: canonical site URL for links in GitHub issue bodies (falls back to VERCEL_URL / localhost).
# Also used for newsletter review links.
PUBLIC_SITE_URL=https://game-rev.vercel.app
