# Browser (Vite inlines at build). Set the same in Vercel → Environment Variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server only (Vite dev + Vercel functions). Never VITE_ prefix.
SUPABASE_SERVICE_ROLE_KEY=
ADD_GAME_PASSWORD=

# Optional: IGDB external genre search on /addgame (Twitch developer app; server-side only).
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
